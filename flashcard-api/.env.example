# FLASHCARD API Environment Variables
# Copy this file to .env and fill in the actual values BEFORE starting the application.
# Do NOT commit the real .env file to Git!

# MongoDB
# E.g., mongodb+srv://username:password@cluster.mongodb.net/flashcard_db?appName=Cluster0
MONGODB_URI=mongodb://localhost:27017/flashcard_db

# JWT Configuration
# Generate a strong 64-character base64-encoded string
JWT_SECRET_KEY=YOUR_SUPER_SECRET_KEY_REPLACE_ME_IN_PRODUCTION

# Social Login - Google
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Social Login - Facebook
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_APP_SECRET=YOUR_FACEBOOK_APP_SECRET

# Cloudinary
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET
