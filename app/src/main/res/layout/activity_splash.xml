<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_screen">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.17" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.81" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineContentStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.12" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineContentEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.88" />

    <ImageView
        android:id="@+id/imageLogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/splash_title"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_logo"
        app:layout_constraintDimensionRatio="220:225"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guidelineTop"
        app:layout_constraintWidth_percent="0.48" />

    <TextView
        android:id="@+id/textSplashTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/splash_title_margin_top"
        android:fontFamily="sans-serif"
        android:letterSpacing="-0.01"
        android:shadowColor="@color/splash_title_shadow"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="10"
        android:text="@string/splash_title"
        android:textColor="?attr/textColor"
        android:textSize="@dimen/splash_title_text_size"
        android:textStyle="bold"
        android:translationY="@dimen/splash_title_translation_y"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="@id/guidelineContentEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineContentStart"
        app:layout_constraintTop_toBottomOf="@id/imageLogo" />

    <TextView
        android:id="@+id/textSplashSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/splash_subtitle_margin_top"
        android:fontFamily="sans-serif"
        android:shadowColor="@color/splash_subtitle_shadow"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:text="@string/splash_subtitle"
        android:textColor="?attr/subTitleColor"
        android:textSize="@dimen/splash_subtitle_text_size"
        android:translationY="@dimen/splash_subtitle_translation_y"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="@id/guidelineContentEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineContentStart"
        app:layout_constraintTop_toBottomOf="@id/textSplashTitle" />

    <TextView
        android:id="@+id/textProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/splash_progress_label_margin_bottom"
        android:fontFamily="sans-serif-medium"
        android:shadowColor="@color/splash_progress_shadow"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="6"
        android:text="@string/splash_progress_initial"
        android:textColor="?attr/buttonColor"
        android:textSize="@dimen/splash_progress_label_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/progressLoading"
        app:layout_constraintEnd_toEndOf="@id/progressLoading"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="@id/progressLoading" />

    <ProgressBar
        android:id="@+id/progressLoading"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="@dimen/splash_progress_height"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/bg_splash_progress"
        app:layout_constraintBottom_toTopOf="@id/textLoadingMessage"
        app:layout_constraintEnd_toEndOf="@id/guidelineContentEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineContentStart"
        app:layout_constraintTop_toTopOf="@id/guidelineBottom" />

    <TextView
        android:id="@+id/textLoadingMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/splash_loading_margin_top"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="@string/splash_loading_message"
        android:textColor="@color/splash_loading_text"
        android:textSize="@dimen/splash_loading_text_size"
        app:layout_constraintEnd_toEndOf="@id/guidelineContentEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineContentStart"
        app:layout_constraintTop_toBottomOf="@id/progressLoading" />

</androidx.constraintlayout.widget.ConstraintLayout>
