<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorOnBackground"
    tools:context=".presentation.feature.learning.StudyResultFragment">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="@dimen/learning_top_bar_height"
        android:layout_marginTop="@dimen/learning_space_sm"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/learning_space_md"
        android:paddingEnd="@dimen/learning_screen_padding_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="@dimen/learning_icon_button_size"
            android:layout_height="@dimen/learning_icon_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back" />

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/app_study_result"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/learning_toolbar_large_text_size"
            android:textStyle="bold" />

        <Space
            android:layout_width="@dimen/learning_icon_button_size"
            android:layout_height="@dimen/learning_icon_button_size" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/learning_screen_padding_horizontal"
        android:paddingTop="@dimen/learning_space_sm"
        android:paddingBottom="@dimen/learning_space_lg"
        app:layout_constraintBottom_toTopOf="@id/btnContinue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <FrameLayout
            android:layout_width="@dimen/learning_result_circle_size"
            android:layout_height="@dimen/learning_result_circle_size"
            android:layout_marginTop="@dimen/learning_space_sm">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_outer" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/learning_result_circle_inset"
                android:background="@drawable/bg_circle_inner" />

            <ImageView
                android:id="@+id/iconTrophy"
                android:layout_width="@dimen/learning_result_icon_size"
                android:layout_height="@dimen/learning_result_icon_size"
                android:layout_gravity="center"
                android:src="@drawable/ic_trophy" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvCongrats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/learning_space_lg"
            android:text="@string/app_study_result_congratulation"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/learning_result_title_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/learning_space_sm"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/app_study_result_congratulation_subTitle"
            android:textColor="?attr/subTitleColor"
            android:textSize="@dimen/learning_body_text_size" />

        <GridLayout
            android:id="@+id/feedbackGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/learning_space_md"
            android:alignmentMode="alignBounds"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true">

            <include
                android:id="@+id/cardStudiedResult"
                layout="@layout/item_learning_result_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/learning_feedback_card_height"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1" />

            <include
                android:id="@+id/cardCorrectResult"
                layout="@layout/item_learning_result_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/learning_feedback_card_height"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1" />

            <include
                android:id="@+id/cardIncorrectResult"
                layout="@layout/item_learning_result_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/learning_feedback_card_height"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1" />

            <include
                android:id="@+id/cardTimeResult"
                layout="@layout/item_learning_result_card"
                android:layout_width="0dp"
                android:layout_height="@dimen/learning_feedback_card_height"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1" />
        </GridLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="0dp"
        android:layout_height="@dimen/learning_cta_height_large"
        android:layout_marginHorizontal="@dimen/learning_screen_padding_horizontal"
        android:layout_marginTop="@dimen/learning_space_sm"
        android:layout_marginBottom="@dimen/learning_space_lg"
        android:backgroundTint="?attr/buttonColor"
        android:text="@string/learning_start"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/learning_toolbar_text_size"
        android:textStyle="bold"
        app:cornerRadius="@dimen/learning_card_radius"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
