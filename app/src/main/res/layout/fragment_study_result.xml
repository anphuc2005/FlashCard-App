<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.module_learn_fragment.StudyResultFragment"
    android:background="?attr/colorOnBackground">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back"
            />

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/app_study_result"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/textColor"/>

        <View
            android:layout_width="40dp"
            android:layout_height="40dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="90dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_marginTop="12dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_outer"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="20dp"
                    android:background="@drawable/bg_circle_inner"/>

                <ImageView
                    android:id="@+id/iconTrophy"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_trophy"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvCongrats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tuyệt vời!"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="?attr/textColor"/>

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/app_study_result_congratulation_subTitle"
                android:textSize="14sp"
                android:textColor="?attr/subTitleColor"/>

            <GridLayout
                android:id="@+id/feedbackGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignBounds"
                android:useDefaultMargins="true">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAgain"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/componentBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_cards"
                            app:tint="?attr/iconBlue" />
                        <TextView
                            android:id="@+id/countStudied"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="40"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/textColor"/>
                        <TextView
                            android:id="@+id/cardStudied"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thẻ đã học"
                            android:textSize="14sp"
                            android:textColor="?attr/subTitleColor"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hard -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHard"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/componentBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_correct"/>
                        <TextView
                            android:id="@+id/countCorrect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20x20"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/textColor"/>
                        <TextView
                            android:id="@+id/subCountCorrect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chính xác"
                            android:textSize="14sp"
                            android:textColor="?attr/subTitleColor"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGood"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/componentBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_incorrect"/>
                        <TextView
                            android:id="@+id/countIncorrect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1x20"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/textColor"/>
                        <TextView
                            android:id="@+id/subCountIncorrect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sai sót"
                            android:textSize="14sp"
                            android:textColor="?attr/subTitleColor"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEasy"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="1"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/componentBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_time"/>
                        <TextView
                            android:id="@+id/timeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12:45"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/textColor"/>
                        <TextView
                            android:id="@+id/subTimeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thời gian"
                            android:textSize="14sp"
                            android:textColor="?attr/subTitleColor"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- CTA -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="18dp"
        android:text="Học tiếp"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="#2E6BFF"
        android:textColor="#FFFFFF"
        app:cornerRadius="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>