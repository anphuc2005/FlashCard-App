<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.module_learn_fragment.BackCardFragment"
    android:background="?attr/colorOnBackground">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_close"
            />

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/app_back_card_learnLesson"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/textColor" />

        <View
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            />
    </LinearLayout>

    <!-- Progress section -->
    <LinearLayout
        android:id="@+id/progressSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_back_card_learnLesson"
                android:textColor="?attr/subTitleColor"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13/20"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#2E6BFF" />
        </LinearLayout>

        <com.example.flashcardapp.utils.chart.ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.Material3.LinearProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="6dp"
            />
    </LinearLayout>

    <!-- Content area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        app:layout_constraintTop_toBottomOf="@id/progressSection"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image -->
            <ImageView
                android:id="@+id/cardImage"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/test" />

            <!-- Answer card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                android:backgroundTint="?attr/componentBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tagAnswer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_blue"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="ANSWER"
                        android:textAllCaps="true"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="#2E6BFF" />

                    <TextView
                        android:id="@+id/cardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Kiến thức cơ bản"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#0F1F3C"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/cardDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="The detailed explanation or translation of the flashcard content goes here to help the learner understand the concept in depth."
                        android:textColor="#5A6475"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feedback title -->
            <TextView
                android:id="@+id/feedbackTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="HOW WAS IT?"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textSize="13sp"
                android:gravity="center"
                android:textColor="#7D8798" />

            <!-- Feedback grid -->
            <GridLayout
                android:id="@+id/feedbackGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignBounds"
                android:useDefaultMargins="true">

                <!-- Again -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAgain"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconRed"
                    app:strokeWidth="1dp"
                    android:backgroundTint="?attr/iconRedBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_again"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lại"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="?attr/iconRed"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Hard -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHard"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconYellow"
                    app:strokeWidth="1dp"
                    android:backgroundTint="?attr/iconYellowBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_difficult"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khó"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="?attr/iconYellow"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Good -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGood"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconBlue"
                    app:strokeWidth="1dp"
                    android:backgroundTint="?attr/iconBlueBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_good"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tốt"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="?attr/iconBlue"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Easy -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEasy"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_row="1"
                    android:layout_column="1"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/iconGreen"
                    app:strokeWidth="1dp"
                    android:backgroundTint="?attr/iconGreenBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_easy"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dễ"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="?attr/iconGreen"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>