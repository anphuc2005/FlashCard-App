<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/learning_background"
    tools:context=".presentation.feature.learning.BackCardFragment">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/learning_top_bar_height"
        android:background="@color/learning_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/learning_screen_padding_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="@dimen/learning_icon_button_size"
            android:layout_height="@dimen/learning_icon_button_size"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="@dimen/learning_top_bar_margin"
            android:src="@drawable/ic_close"
            app:tint="@color/learning_text_primary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/progressSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/learning_surface"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/learning_screen_padding_horizontal"
        android:paddingTop="@dimen/learning_space_sm"
        android:paddingBottom="@dimen/learning_space_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/learning_session_progress"
                android:textColor="@color/learning_text_secondary"
                android:textSize="@dimen/learning_body_text_size" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/learning_space_md"
                android:textColor="@color/learning_primary"
                android:textSize="@dimen/learning_body_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="01:00"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/learning_primary"
                android:textSize="@dimen/learning_body_text_size"
                android:textStyle="bold"
                tools:text="13/20" />
        </LinearLayout>

        <com.example.flashcardapp.core.utils.chart.ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/learning_progress_height"
            android:layout_marginTop="@dimen/learning_space_md" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAnswer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/learning_screen_padding_large"
        android:layout_marginTop="@dimen/learning_space_lg"
        android:layout_marginEnd="@dimen/learning_screen_padding_large"
        android:layout_marginBottom="@dimen/learning_space_lg"
        android:backgroundTint="@color/learning_surface"
        app:cardCornerRadius="@dimen/learning_card_radius_figma"
        app:cardElevation="@dimen/learning_zero"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressSection"
        app:strokeColor="@color/learning_soft_border"
        app:strokeWidth="@dimen/learning_stroke_width">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/answerImageBottomGuide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.38" />

            <ImageView
                android:id="@+id/cardImage"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@color/learning_chip_unselected"
                android:scaleType="centerCrop"
                android:src="@drawable/test"
                app:layout_constraintBottom_toTopOf="@id/answerImageBottomGuide"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_min="@dimen/learning_back_visual_min_height"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/answerContent"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/learning_card_padding_large"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/answerImageBottomGuide">

                <TextView
                    android:id="@+id/tagAnswer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_blue"
                    android:paddingHorizontal="@dimen/learning_top_bar_margin"
                    android:paddingVertical="@dimen/learning_space_xs"
                    android:text="@string/learning_answer_label"
                    android:textAllCaps="true"
                    android:textColor="@color/learning_primary"
                    android:textSize="@dimen/learning_label_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/learning_space_lg"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="2"
                    android:textColor="@color/learning_text_primary"
                    android:textSize="@dimen/learning_card_question_text_size"
                    android:textStyle="bold"
                    tools:text="Kiến thức cơ bản" />

                <TextView
                    android:id="@+id/cardDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/learning_space_md"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="4"
                    android:textColor="@color/learning_text_secondary"
                    android:textSize="@dimen/learning_answer_text_size"
                    tools:text="The detailed explanation or translation of the flashcard content goes here." />

                <ImageButton
                    android:id="@+id/btnSpeakAnswer"
                    android:layout_width="@dimen/learning_icon_button_size"
                    android:layout_height="@dimen/learning_icon_button_size"
                    android:layout_marginTop="@dimen/learning_space_lg"
                    android:background="@drawable/bg_learning_icon_soft"
                    android:contentDescription="@string/learning_tts_read_answer"
                    android:padding="@dimen/learning_space_sm"
                    android:src="@drawable/ic_volume_up"
                    app:tint="@color/learning_primary" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
