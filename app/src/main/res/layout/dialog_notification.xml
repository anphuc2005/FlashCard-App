<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_round"
    android:orientation="vertical"
    android:padding="@dimen/notification_settings_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/notification_settings_header_icon_size"
            android:layout_height="@dimen/notification_settings_header_icon_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_notif_shortcut"
            app:tint="?attr/iconBlue" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/notification_settings_header_spacing"
            android:text="@string/notification_settings_title"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/notification_settings_title_size"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/notification_settings_row_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="@dimen/notification_settings_row_padding_end">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/notification_settings_study"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/notification_settings_text_size"
            android:textStyle="bold" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchStudy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:thumbTint="@color/switch_thumb_blue"
            app:trackTint="@color/switch_track_blue" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/notification_settings_divider_height"
        android:background="@color/app_notification_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/notification_settings_row_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="@dimen/notification_settings_row_padding_end">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/notification_settings_new_deck"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/notification_settings_text_size"
            android:textStyle="bold" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchNewDeck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            app:thumbTint="@color/switch_thumb_gray"
            app:trackTint="@color/switch_track_gray" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/notification_settings_divider_height"
        android:background="@color/app_notification_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/notification_settings_row_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingEnd="@dimen/notification_settings_row_padding_end">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/notification_settings_achievement"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/notification_settings_text_size"
            android:textStyle="bold" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAchievement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:thumbTint="@color/switch_thumb_blue"
            app:trackTint="@color/switch_track_blue" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnApply"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="@dimen/notification_settings_button_height"
        android:layout_marginTop="@dimen/notification_settings_button_margin_top"
        android:backgroundTint="@color/switch_track_gray"
        android:text="@string/notification_settings_apply"
        android:textAllCaps="false"
        android:textColor="@color/switch_thumb_blue"
        android:textSize="@dimen/notification_settings_text_size"
        android:textStyle="bold"
        app:cornerRadius="@dimen/notification_settings_button_radius" />
</LinearLayout>
