<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="?attr/componentBackground"
    app:cardCornerRadius="@dimen/learning_card_radius"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/learning_top_bar_margin">

        <ImageView
            android:id="@+id/resultIcon"
            android:layout_width="@dimen/learning_feedback_icon_size"
            android:layout_height="@dimen/learning_feedback_icon_size"
            app:tint="?attr/iconBlue" />

        <TextView
            android:id="@+id/resultValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/learning_result_value_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/resultLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/subTitleColor"
            android:textSize="@dimen/learning_body_text_size" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
