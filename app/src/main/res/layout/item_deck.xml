<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true"
    app:strokeColor="@android:color/transparent"
    android:backgroundTint="?attr/componentBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/deckTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Từ vựng IELTS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="?attr/textColor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_bias="0"/>

        <ImageButton
            android:id="@+id/editBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:src="@drawable/ic_more_vert"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <TextView
            android:id="@+id/stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="120 thẻ · Đã học 45"
            android:textSize="14sp"
            android:textColor="?attr/subTitleColor"
            app:layout_constraintTop_toBottomOf="@id/deckTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Progress label -->
        <TextView
            android:id="@+id/progressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tiến độ"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2E6BFF"
            app:layout_constraintTop_toBottomOf="@id/stats"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Progress percent -->
        <TextView
            android:id="@+id/progressPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="38%"
            android:textSize="14sp"
            android:textColor="#0F1F3C"
            app:layout_constraintTop_toBottomOf="@id/stats"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.example.flashcardapp.core.utils.chart.ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="0dp"
            android:layout_height="10dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/progressLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <TextView
            android:id="@+id/lastStudied"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Học lần cuối: 2 giờ trước"
            android:textSize="13sp"
            android:textStyle="italic"
            android:textColor="?attr/subTitleColor"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ctaLearn"/>

        <!-- CTA Learn now -->
        <LinearLayout
            android:id="@+id/ctaLearn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/ctaText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Học ngay"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/iconBlue"/>

            <ImageView
                android:id="@+id/ctaIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_play"
                app:tint="?attr/iconBlue" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>