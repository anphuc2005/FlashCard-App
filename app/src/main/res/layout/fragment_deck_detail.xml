<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorOnBackground"
    tools:context=".presentation.feature.learning.DeckDetailFragment">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="@dimen/learning_top_bar_height"
        android:layout_margin="@dimen/learning_top_bar_margin"
        android:backgroundTint="?attr/componentBackground"
        app:cardCornerRadius="@dimen/learning_top_bar_radius"
        app:cardElevation="@dimen/learning_card_elevation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/learning_icon_button_large_size"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/toolbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/app_deck_detail"
                android:textColor="?attr/textColor"
                android:textSize="@dimen/learning_toolbar_text_size"
                android:textStyle="bold" />

            <View
                android:id="@+id/btnMenu"
                android:layout_width="@dimen/learning_icon_button_large_size"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:paddingHorizontal="@dimen/learning_space_lg"
        android:paddingTop="@dimen/learning_space_sm"
        app:layout_constraintBottom_toTopOf="@+id/ctaButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/learning_content_bottom_padding">

            <TextView
                android:id="@+id/deckTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/learning_space_md"
                android:textColor="?attr/textColor"
                android:textSize="@dimen/learning_title_text_size"
                android:textStyle="bold"
                tools:text="IELTS Vocabulary" />

            <View
                android:id="@+id/titlePlaceholder"
                android:layout_width="220dp"
                android:layout_height="28dp"
                android:layout_marginTop="@dimen/learning_space_md"
                android:background="@drawable/bg_learning_visual_placeholder"
                android:visibility="gone" />

            <TextView
                android:id="@+id/deckDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/learning_space_xs"
                android:textColor="?attr/subTitleColor"
                android:textSize="@dimen/learning_caption_text_size"
                tools:text="Essential vocabulary for preparation." />

            <View
                android:id="@+id/descPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginTop="@dimen/learning_space_xs"
                android:background="@drawable/bg_learning_visual_placeholder"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/learning_space_lg"
                android:gravity="center"
                android:orientation="horizontal">

                <include
                    android:id="@+id/statTotalCard"
                    layout="@layout/item_learning_stat_card"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/learning_stat_card_height"
                    android:layout_marginEnd="@dimen/learning_space_sm"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/statLearnedCard"
                    layout="@layout/item_learning_stat_card"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/learning_stat_card_height"
                    android:layout_marginHorizontal="@dimen/learning_space_sm"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/statNewCard"
                    layout="@layout/item_learning_stat_card"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/learning_stat_card_height"
                    android:layout_marginStart="@dimen/learning_space_sm"
                    android:layout_weight="1" />
            </LinearLayout>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/learning_space_lg"
                android:backgroundTint="?attr/colorOnBackground"
                app:tabIndicatorColor="?attr/buttonColor"
                app:tabIndicatorHeight="@dimen/learning_space_xs"
                app:tabSelectedTextColor="?attr/buttonColor"
                app:tabTextColor="?attr/subTitleColor">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_deck_detail_all_card" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_deck_detail_marked" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_deck_detail_mastery" />
            </com.google.android.material.tabs.TabLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/learning_space_md"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:listitem="@layout/item_learning_card_preview" />

            <LinearLayout
                android:id="@+id/cardsPlaceholderContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/learning_space_md"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginBottom="@dimen/learning_space_sm"
                    android:background="@drawable/bg_learning_visual_placeholder" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginBottom="@dimen/learning_space_sm"
                    android:background="@drawable/bg_learning_visual_placeholder" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_learning_visual_placeholder" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/ctaButton"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="0dp"
        android:layout_height="@dimen/learning_cta_height"
        android:layout_marginHorizontal="@dimen/learning_screen_padding_horizontal"
        android:layout_marginBottom="@dimen/learning_space_xl"
        android:backgroundTint="?attr/buttonColor"
        android:icon="@drawable/ic_play"
        android:text="@string/learning_start"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="@dimen/learning_toolbar_text_size"
        android:textStyle="bold"
        app:cornerRadius="@dimen/learning_card_radius"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
