<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="70dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#EEF1F6"
    app:strokeWidth="1dp"
    android:backgroundTint="?attr/componentBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <FrameLayout
            android:id="@+id/optionIconBg"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="?attr/iconBlueBackground">

            <ImageView
                android:id="@+id/optionIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_1"/>
        </FrameLayout>

        <TextView
            android:id="@+id/optionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Bộ thẻ của tôi"
            android:textColor="#0F1F3C"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_next"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>