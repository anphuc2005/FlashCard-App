<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.fragment.AccountFragment"
    android:background="?attr/colorOnBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="18dp"
                android:gravity="center_vertical"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/avatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_account"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_avatar_circle"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/profileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nam Nguyễn"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#0F1F3C"/>

                        <TextView
                            android:id="@+id/profileSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Học giả chuyên cần"
                            android:textSize="13sp"
                            android:textColor="#8A96A8"/>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        android:backgroundTint="?attr/componentBackground"
                        app:strokeColor="?attr/componentBackground">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_fire"
                                app:tint="?attr/iconGreen"/>

                            <TextView
                                android:id="@+id/tv_Streak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="12"
                                android:textColor="?attr/iconGreen"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- Stats strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingTop="12dp"
                android:paddingBottom="6dp"
                android:background="#F5F7FB">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#EEF1F6"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/componentBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ĐÃ THUỘC"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#7D8798"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/statLearned"
                            android:layout_marginTop="6dp"
                            android:text="1,240"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2E6BFF"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#EEF1F6"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/componentBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NGÀY HỌC"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#7D8798"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/statDays"
                            android:layout_marginTop="6dp"
                            android:text="45"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2E6BFF"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#EEF1F6"
                    app:strokeWidth="0dp"
                    android:backgroundTint="?attr/componentBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="XẾP HẠNG"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#7D8798"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/statRank"
                            android:layout_marginTop="6dp"
                            android:text="#12"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2E6BFF"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="18dp">

                <include layout="@layout/item_profile_option"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:id="@+id/optionMyCards"
                    android:layout_marginTop="6dp"
                    android:tag="Bộ thẻ của tôi"
                    />

                <include layout="@layout/item_profile_option"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:id="@+id/optionSaved"
                    android:layout_marginTop="10dp"
                    android:tag="Thư đã lưu"
                    />

                <include layout="@layout/item_profile_option"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:id="@+id/optionSettings"
                    android:layout_marginTop="10dp"
                    android:tag="Cài đặt"
                    />

                <include layout="@layout/item_profile_option"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:id="@+id/optionLogout"
                    android:layout_marginTop="10dp"
                    android:tag="Đăng xuất"
                    />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>