<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorOnBackground">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineContentStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.07" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineContentEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.93" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottomShadeTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.84" />

    <View
        android:id="@+id/bottomShade"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="?attr/colorOnBackground"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/guidelineContentEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineContentStart"
        app:layout_constraintTop_toTopOf="@id/guidelineBottomShadeTop" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingTop="@dimen/forgot_screen_padding_top"
        android:paddingBottom="@dimen/auth_screen_padding_bottom"
        app:layout_constraintBottom_toTopOf="@id/bottomShade"
        app:layout_constraintEnd_toEndOf="@id/guidelineContentEnd"
        app:layout_constraintStart_toStartOf="@id/guidelineContentStart"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="@dimen/auth_back_button_size"
            android:layout_height="@dimen/auth_back_button_size"
            android:layout_marginTop="@dimen/forgot_back_margin_top"
            android:background="@android:color/transparent"
            android:contentDescription="@string/common_back"
            android:padding="@dimen/auth_back_button_padding"
            android:src="@drawable/ic_onboarding_back"
            app:tint="?attr/textColor" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/forgot_title_margin_top"
            android:text="Quên mật khẩu?"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/auth_large_title_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/forgot_subtitle_margin_top"
            android:text="Nhập email của bạn để nhận mã khôi phục."
            android:textColor="?attr/subTitleColor"
            android:textSize="@dimen/auth_subtitle_text_size" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/forgot_label_margin_top"
            android:text="Email"
            android:textColor="?attr/textColor"
            android:textSize="@dimen/auth_label_text_size"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutEmail"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/auth_field_spacing_top"
            android:hint="example@email.com"
            app:boxBackgroundColor="@color/auth_input_background"
            app:boxCornerRadiusBottomEnd="@dimen/auth_input_corner_radius"
            app:boxCornerRadiusBottomStart="@dimen/auth_input_corner_radius"
            app:boxCornerRadiusTopEnd="@dimen/auth_input_corner_radius"
            app:boxCornerRadiusTopStart="@dimen/auth_input_corner_radius"
            app:boxStrokeColor="@color/auth_input_stroke_selector"
            app:boxStrokeWidth="@dimen/auth_input_stroke_width"
            app:boxStrokeWidthFocused="@dimen/auth_input_stroke_width">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingTop="@dimen/auth_input_vertical_padding"
                android:paddingBottom="@dimen/auth_input_vertical_padding"
                android:textColor="?attr/textColor"
                android:textColorHint="@color/auth_input_hint" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSendVerificationCode"
            android:layout_width="match_parent"
            android:layout_height="@dimen/auth_button_height"
            android:layout_marginTop="@dimen/auth_section_spacing_small"
            android:backgroundTint="?attr/buttonColor"
            android:elevation="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Gửi mã xác nhận"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/auth_button_text_size"
            android:textStyle="bold"
            app:cornerRadius="@dimen/auth_small_button_corner_radius" />

        <TextView
            android:id="@+id/textNeedHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/auth_section_spacing_small"
            android:gravity="center"
            android:text="Bạn cần trợ giúp? Liên hệ hỗ trợ"
            android:textColor="?attr/subTitleColor"
            android:textSize="@dimen/auth_label_text_size" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
