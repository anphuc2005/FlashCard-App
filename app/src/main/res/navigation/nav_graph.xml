<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/launchRouterFragment">

    <fragment
        android:id="@+id/launchRouterFragment"
        android:name="com.example.flashcardapp.ui.feature.launch.LaunchRouterFragment"
        android:label="fragment_launch_router"
        tools:layout="@layout/fragment_launch_router">
        <action
            android:id="@+id/action_launchRouterFragment_to_onboardingFragment"
            app:destination="@id/onboardingFragment"
            app:popUpTo="@id/launchRouterFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_launchRouterFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/launchRouterFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_launchRouterFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/launchRouterFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.example.flashcardapp.ui.feature.onboarding.OnboardingFragment"
        android:label="fragment_onboarding"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboardingFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.flashcardapp.ui.feature.auth.presentation.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_forgotPasswordFragment"
            app:destination="@id/forgotPasswordFragment" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/launchRouterFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.flashcardapp.ui.feature.auth.presentation.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_otpVerificationFragment"
            app:destination="@id/otpVerificationFragment" />
    </fragment>

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.flashcardapp.ui.feature.auth.presentation.ForgotPasswordFragment"
        android:label="fragment_forgot_password"
        tools:layout="@layout/fragment_forgot_password">
        <action
            android:id="@+id/action_forgotPasswordFragment_to_otpVerificationFragment"
            app:destination="@id/otpVerificationFragment" />
    </fragment>

    <fragment
        android:id="@+id/otpVerificationFragment"
        android:name="com.example.flashcardapp.ui.feature.auth.presentation.OtpVerificationFragment"
        android:label="fragment_otp_verification"
        tools:layout="@layout/fragment_otp_verification" />

    <fragment
        android:id="@id/homeFragment"
        android:name="com.example.flashcardapp.ui.fragment.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" />
    <fragment
        android:id="@id/accountFragment"
        android:name="com.example.flashcardapp.ui.fragment.AccountFragment"
        android:label="fragment_account"
        tools:layout="@layout/fragment_account" />
    <fragment
        android:id="@id/deckFragment"
        android:name="com.example.flashcardapp.ui.fragment.DeckFragment"
        android:label="fragment_deck"
        tools:layout="@layout/fragment_deck" >
        <action
            android:id="@+id/action_deckFragment_to_addDeskFragment"
            app:destination="@id/addDeskFragment" />
    </fragment>
    <fragment
        android:id="@id/discoverFragment"
        android:name="com.example.flashcardapp.ui.fragment.DiscoverFragment"
        android:label="fragment_discover"
        tools:layout="@layout/fragment_discover" />
    <fragment
        android:id="@id/statisticFragment"
        android:name="com.example.flashcardapp.ui.fragment.StatisticFragment"
        android:label="fragment_statistic"
        tools:layout="@layout/fragment_statistic" />
    <fragment
        android:id="@+id/addDeskFragment"
        android:name="com.example.flashcardapp.ui.module_add_fragment.AddDeskFragment"
        android:label="fragment_add_desk"
        tools:layout="@layout/fragment_add_desk" />
</navigation>
